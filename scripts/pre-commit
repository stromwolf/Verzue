#!/bin/bash

# Security pre-commit hook for Verzue
# Scans for sensitive patterns in staged files.

# Bypass with SKIP_SECURITY_HOOK=1
if [ "$SKIP_SECURITY_HOOK" = "1" ]; then
    echo "⚠️ Skipping security hook (SKIP_SECURITY_HOOK=1)"
    exit 0
fi

# Patterns to scan
# 1. pickle.load/dump: Arbitrary code execution risk
# 2. account.json: Likely contains credentials
# 3. "password": Hardcoded credentials
declare -a PATTERNS=("pickle.load" "pickle.dump" "account.json" "\"password\":")

# Get staged .py files (added/copied/modified)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep "\.py$")

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

FOUND_RISK=0

for pattern in "${PATTERNS[@]}"; do
    # Search for pattern in staged files
    # We use grep -n to show line numbers
    MATCHES=$(grep -n "$pattern" $STAGED_FILES 2>/dev/null)
    if [ ! -z "$MATCHES" ]; then
        echo "❌ SECURITY RISK DETECTED: Found '$pattern' in staged files:"
        echo "$MATCHES" | while read -r line; do echo "   -> $line"; done
        echo ""
        FOUND_RISK=1
    fi
done

if [ "$FOUND_RISK" -eq 1 ]; then
    echo "🛑 COMMIT BLOCKED"
    echo "Patterns such as 'pickle' or hardcoded secrets are forbidden in this repo."
    echo "Please remove the sensitive code or use secure alternatives (json, .env secrets)."
    echo ""
    echo "If this is a false positive or an emergency, bypass with:"
    echo "  SKIP_SECURITY_HOOK=1 git commit ..."
    exit 1
fi

exit 0
